<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.byodsystem.byod.controller.StudentController">

    <top>
        <Label text="STUDENT REGISTRATION"
               style="-fx-font-size: 18px; -fx-padding: 15;"/>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <TextField fx:id="studentIdField" promptText="Student ID"/>
            <TextField fx:id="nameField" promptText="Full Name"/>
            <TextField fx:id="courseField" promptText="Course/Program"/>
            <ComboBox fx:id="yearComboBox" promptText="Year Level"/>

            <TextField fx:id="searchField" promptText="Search Student"/>

            <HBox spacing="10">
                <Button text="Add Student" onAction="#addStudent"/>
                <Button text="Update" onAction="#updateStudent"/>
                <Button text="Delete" onAction="#deleteStudent"/>
                <Button text="Search" onAction="#searchStudent"/>
                <Button text="Clear" onAction="#clearFields"/>
            </HBox>

            <TableView fx:id="studentTable">

                <columns>
                    <TableColumn fx:id="colStudentId" text="ID"/>
                    <TableColumn fx:id="colName" text="Name"/>
                    <TableColumn fx:id="colCourse" text="Course"/>
                    <TableColumn fx:id="colYear" text="Year"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>