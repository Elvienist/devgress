<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.fxml.com/fxml/1"
      fx:controller="com.example.byodsystem.byod.controller.SettingsController"
      style="-fx-background-color: #f5f5f5;">

    <!-- Top Bar -->
    <HBox style="-fx-background-color: white; -fx-padding: 12 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" alignment="CENTER_LEFT" spacing="10">
        <Label text="📅" style="-fx-font-size: 14px; -fx-text-fill: #555555;"/>
        <Label fx:id="lblDate" text="" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <StackPane>
            <Button style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" text="🔔"/>
            <Label text="•" style="-fx-text-fill: #8B0000; -fx-font-size: 18px;" StackPane.alignment="TOP_RIGHT" translateX="4" translateY="-4"/>
        </StackPane>
        <HBox alignment="CENTER" spacing="8">
            <VBox alignment="CENTER_RIGHT">
                <Label text="Administrator" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #222222;"/>
                <HBox alignment="CENTER_RIGHT">
                    <Label text="Admin" style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-size: 10px; -fx-padding: 1 6; -fx-background-radius: 4;"/>
                </HBox>
            </VBox>
            <VBox alignment="CENTER" style="-fx-background-color: #8B0000; -fx-min-width: 34px; -fx-min-height: 34px; -fx-background-radius: 17;">
                <Label text="A" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </HBox>

    <!-- Main Content -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: #f5f5f5; -fx-background: #f5f5f5; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="20" style="-fx-padding: 30 60 30 60;">

            <VBox spacing="4">
                <Label text="System Settings" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                <Label text="Configure system-wide settings and preferences" style="-fx-font-size: 13px; -fx-text-fill: #888888;"/>
            </VBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e8e8e8; -fx-border-radius: 10; -fx-padding: 24;" spacing="20">

                <HBox spacing="14" alignment="CENTER_LEFT">
                    <VBox alignment="CENTER" style="-fx-background-color: #8B0000; -fx-min-width: 44px; -fx-min-height: 44px; -fx-background-radius: 10;">
                        <Label text="⚙" style="-fx-text-fill: white; -fx-font-size: 20px;"/>
                    </VBox>
                    <VBox spacing="2">
                        <Label text="System Configuration" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;"/>
                        <Label text="Manage global system settings" style="-fx-font-size: 12px; -fx-text-fill: #888888;"/>
                    </VBox>
                </HBox>

                <Separator/>

                <VBox spacing="6">
                    <Label text="Institution Name" style="-fx-font-size: 13px; -fx-text-fill: #444444;"/>
                    <TextField fx:id="txtInstitutionName" maxWidth="Infinity"
                               style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-pref-height: 40px; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Academic Year" style="-fx-font-size: 13px; -fx-text-fill: #444444;"/>
                    <TextField fx:id="txtAcademicYear" maxWidth="Infinity"
                               style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-pref-height: 40px; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Gate Correction Time Boundary (minutes)" style="-fx-font-size: 13px; -fx-text-fill: #444444;"/>
                    <TextField fx:id="txtCorrectionWindow" maxWidth="Infinity"
                               style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-pref-height: 40px; -fx-padding: 0 12;"/>
                    <Label text="Time window within which corrections are clean versus tracked as amendments"
                           style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="End of Day Reminder Time" style="-fx-font-size: 13px; -fx-text-fill: #444444;"/>
                    <TextField fx:id="txtEndOfDayTime" maxWidth="Infinity"
                               style="-fx-background-color: white; -fx-border-color: #cccccc; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-pref-height: 40px; -fx-padding: 0 12;"
                               promptText="HH:MM"/>
                    <Label text="Time when the system triggers end of day unclosed log checks"
                           style="-fx-font-size: 11px; -fx-text-fill: #888888;"/>
                </VBox>

                <Button fx:id="btnSave" text="  Save Settings" maxWidth="Infinity" onAction="#saveSettings"
                        style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-pref-height: 44px; -fx-background-radius: 6; -fx-cursor: hand;">
                    <graphic>
                        <Label text="💾" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </graphic>
                </Button>
            </VBox>

            <Label text="Changes to these settings will take effect immediately and apply system-wide."
                   style="-fx-font-size: 12px; -fx-text-fill: #888888;" alignment="CENTER" maxWidth="Infinity"/>
        </VBox>
    </ScrollPane>
</VBox>
