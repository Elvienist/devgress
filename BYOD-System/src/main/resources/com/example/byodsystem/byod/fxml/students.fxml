<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane minHeight="650.0" minWidth="1150.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.StudentController">
    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="20" left="15" right="15" top="20"/></padding>
            <Label text="BYOD System" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            <Region prefHeight="20.0" />
            <Button fx:id="btnDashboard" text="📊  Dashboard" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnStudents" text="👥  Students" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: #89B893; -fx-text-fill: white;"/>
            <Button fx:id="btnDevices" text="💻  Devices" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnLogs" text="🔄  Ingress-Egress Logs" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnActivity" text="📑  Recent Activity" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnReports" text="📄  Reports" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnSettings" text="⚙️  Settings" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnLogout" text="🚪  Logout" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #EF4444;"/>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="20" right="20"/></padding>
            <Label fx:id="lblDate" text="Date Placeholder" style="-fx-text-fill: #64748B;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="lblAdminName" text="Operator" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblAdminRole" text="Role" style="-fx-font-size: 10; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <HBox spacing="20.0">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20;">
                <Label text="Student Registration" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                <Label text="Student ID"/><TextField fx:id="txtStudentID" promptText="e.g., 2023-00001"/>
                <Label text="Full Name"/><TextField fx:id="txtFullName" promptText="Enter full name"/>
                <HBox spacing="10.0">
                    <VBox HBox.hgrow="ALWAYS"><Label text="Course"/><TextField fx:id="txtCourse"/></VBox>
                    <VBox HBox.hgrow="ALWAYS"><Label text="Year Level"/><TextField fx:id="txtYearLevel"/></VBox>
                </HBox>
                <Label text="Contact Number"/><TextField fx:id="txtContact" promptText="+63 XXX XXX XXXX"/>
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button fx:id="btnClear" text="Clear" style="-fx-background-color: #E2E8F0;"/>
                    <Button fx:id="btnSave" text="Save Student" style="-fx-background-color: #89B893; -fx-text-fill: white; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 20;">
                <TextField fx:id="txtSearch" promptText="Search by name, ID, or course..." style="-fx-pref-height: 35;"/>
                <TableView fx:id="tblStudents" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colID" text="Student ID" prefWidth="100"/>
                        <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                        <TableColumn fx:id="colCourse" text="Course" prefWidth="150"/>
                        <TableColumn fx:id="colYear" text="Year" prefWidth="80"/>
                        <TableColumn fx:id="colContact" text="Contact" prefWidth="120"/>
                        <TableColumn fx:id="colDevices" text="Devices" prefWidth="70"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>
    </center>
</BorderPane>
