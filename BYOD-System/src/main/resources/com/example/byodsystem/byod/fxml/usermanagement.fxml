<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #F9FAFB;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.UserManagementController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="60.0">
                    <children>
                        <VBox alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <children>
                                <Label fx:id="lblDate" text="Date Placeholder" textFill="#6B7280">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                                <Label text="User Management Overview" textFill="#111827">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <HBox alignment="CENTER" spacing="12.0">
                            <children>
                                <VBox alignment="CENTER_RIGHT">
                                    <children>
                                        <Label fx:id="lblUserName" text="Full Name" textFill="#111827">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label fx:id="lblUserRole" text="ROLE" textFill="#6B7280">
                                            <font>
                                                <Font size="11.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                                <StackPane prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #7A0000; -fx-background-radius: 50;">
                                    <children>
                                        <Label fx:id="lblUserInitial" text="A" textFill="WHITE">
                                            <font>
                                                <Font name="System Bold" size="16.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <children>
                        <HBox spacing="6.0" style="-fx-background-color: #E5E7EB; -fx-background-radius: 20; -fx-padding: 4;">
                            <children>
                                <Button fx:id="btnFilterAll" mnemonicParsing="false" onAction="#filterAll" text="All Accounts" />
                                <Button fx:id="btnFilterAdmin" mnemonicParsing="false" onAction="#filterAdmin" text="Administrators" />
                                <Button fx:id="btnFilterSecurity" mnemonicParsing="false" onAction="#filterSecurity" text="Security Officers" />
                                <Button fx:id="btnFilterStudent" mnemonicParsing="false" onAction="#filterStudent" text="Students" />
                            </children>
                        </HBox>
                        <StackPane HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtSearch" onKeyReleased="#handleSearch" prefHeight="38.0" prefWidth="260.0" promptText="Search name or username..." style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 12;" />
                        <Button mnemonicParsing="false" onAction="#handleCreateUser" prefHeight="38.0" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 0 16; -fx-cursor: hand;" text="+ Register New User" />
                    </children>
                </HBox>

                <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #E5E7EB; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="50.0">
                            <padding>
                                <Insets left="16.0" right="16.0" />
                            </padding>
                            <children>
                                <Label text="Registered Directory" textFill="#111827">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <StackPane HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblUserCount" text="0 users" textFill="#6B7280">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                        <TableView fx:id="tblUsers" prefHeight="500.0" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colUsername" prefWidth="130.0" style="-fx-alignment: CENTER;" text="USERNAME" />
                                <TableColumn fx:id="colName" prefWidth="200.0" style="-fx-alignment: CENTER;" text="FULL NAME" />
                                <TableColumn fx:id="colRole" prefWidth="130.0" style="-fx-alignment: CENTER;" text="SYSTEM ROLE" />
                                <TableColumn fx:id="colStatus" prefWidth="120.0" style="-fx-alignment: CENTER;" text="ACCOUNT STATUS" />
                                <TableColumn fx:id="colCreated" prefWidth="140.0" style="-fx-alignment: CENTER;" text="DATE CREATED" />
                                <TableColumn fx:id="colLastLogin" prefWidth="160.0" style="-fx-alignment: CENTER;" text="LAST AUTHENTICATED" />
                                <TableColumn fx:id="colActions" prefWidth="140.0" style="-fx-alignment: CENTER;" text="OPERATIONAL ACTIONS" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>

        <StackPane fx:id="addUserOverlay" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox maxHeight="420.0" maxWidth="580.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                            <children>
                                <Label text="Register New System Identity" textFill="#111827">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <StackPane HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleAddModalClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #9CA3AF;" text="✕">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                        <HBox spacing="16.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                            </padding>
                            <children>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="Full Name" textFill="#374151" />
                                                <TextField fx:id="txtAddFullName" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="Username" textFill="#374151" />
                                                <TextField fx:id="txtAddUsername" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                            </children>
                                        </VBox>
                                        <VBox fx:id="boxAddStudentRef" spacing="4.0">
                                            <children>
                                                <Label text="Student Reference ID" textFill="#374151" />
                                                <TextField fx:id="txtAddStudentRef" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                                <Label fx:id="lblAddRefError" text="This Student ID is required and must exist in our system." textFill="#7A0000" visible="false" wrapText="true">
                                                    <font>
                                                        <Font name="System Bold Italic" size="11.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox spacing="12.0">
                                            <children>
                                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                                    <children>
                                                        <Label text="System Role" textFill="#374151" />
                                                        <ComboBox fx:id="cmbAddRole" maxWidth="1.7976931348623157E308" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-color: white;" />
                                                    </children>
                                                </VBox>
                                                <VBox spacing="4.0" prefWidth="140.0">
                                                    <children>
                                                        <Label text="Initial Status" textFill="#374151" />
                                                        <HBox prefHeight="34.0">
                                                            <children>
                                                                <Button fx:id="btnAddStatusActive" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddStatusActive" text="Active" HBox.hgrow="ALWAYS" />
                                                                <Button fx:id="btnAddStatusInactive" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleAddStatusInactive" text="Inactive" HBox.hgrow="ALWAYS" />
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="Security Password" textFill="#374151" />
                                                <PasswordField fx:id="txtAddPassword" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0">
                                            <children>
                                                <Label text="Confirm Password" textFill="#374151" />
                                                <PasswordField fx:id="txtAddConfirmPassword" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="12.0" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 12 12;">
                            <padding>
                                <Insets right="20.0" />
                            </padding>
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleAddModalClose" prefHeight="34.0" prefWidth="80.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-text-fill: #374151; -fx-cursor: hand;" text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#handleAddModalSubmit" prefHeight="34.0" prefWidth="110.0" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Save Identity" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>

        <StackPane fx:id="editUserOverlay" managed="false" style="-fx-background-color: rgba(0,0,0,0.4);" visible="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox maxHeight="340.0" maxWidth="580.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12;">
                    <children>
                        <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-border-color: #E5E7EB; -fx-border-width: 0 0 1 0;">
                            <padding>
                                <Insets left="20.0" right="20.0" />
                            </padding>
                            <children>
                                <Label text="Modify System Account Parameters" textFill="#111827">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <StackPane HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleEditModalClose" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #9CA3AF;" text="✕">
                                    <font>
                                        <Font size="14.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                        <VBox spacing="14.0" VBox.vgrow="ALWAYS">
                            <padding>
                                <Insets bottom="16.0" left="20.0" right="20.0" top="16.0" />
                            </padding>
                            <children>
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Full Name" textFill="#374151" />
                                                <TextField fx:id="txtEditFullName" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Username (Read-Only)" textFill="#374151" />
                                                <TextField fx:id="txtEditUsername" editable="false" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #E5E7EB; -fx-border-radius: 6; -fx-background-color: #F3F4F6; -fx-text-fill: #6B7280;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="16.0">
                                    <children>
                                        <VBox fx:id="boxEditStudentRef" spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Student Reference ID" textFill="#374151" />
                                                <TextField fx:id="txtEditStudentRef" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6;" />
                                                <Label fx:id="lblEditRefError" text="This Student ID is required and must exist in our system." textFill="#7A0000" visible="false" wrapText="true">
                                                    <font>
                                                        <Font name="System Bold Italic" size="11.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" prefWidth="180.0">
                                            <children>
                                                <Label text="System Role" textFill="#374151" />
                                                <ComboBox fx:id="cmbEditRole" maxWidth="1.7976931348623157E308" prefHeight="34.0" style="-fx-background-radius: 6; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-color: white;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" prefWidth="140.0">
                                            <children>
                                                <Label text="Account Status" textFill="#374151" />
                                                <HBox prefHeight="34.0">
                                                    <children>
                                                        <Button fx:id="btnEditStatusActive" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEditStatusActive" text="Active" HBox.hgrow="ALWAYS" />
                                                        <Button fx:id="btnEditStatusInactive" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleEditStatusInactive" text="Inactive" HBox.hgrow="ALWAYS" />
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="12.0" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 12 12;">
                            <padding>
                                <Insets right="20.0" />
                            </padding>
                            <children>
                                <Button mnemonicParsing="false" onAction="#handleEditModalClose" prefHeight="34.0" prefWidth="80.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-text-fill: #374151; -fx-cursor: hand;" text="Cancel" />
                                <Button mnemonicParsing="false" onAction="#handleEditModalSubmit" prefHeight="34.0" prefWidth="110.0" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;" text="Save Changes" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>

        <StackPane fx:id="toastOverlay" managed="false" mouseTransparent="true" visible="false" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <HBox fx:id="toastBox" alignment="CENTER" spacing="10.0" style="-fx-background-color: #1F2937; -fx-background-radius: 8; -fx-padding: 12 24; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 4);">
                    <children>
                        <Label text="📢" textFill="WHITE">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label fx:id="toastMessage" text="Action completed successfully." textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="13.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>