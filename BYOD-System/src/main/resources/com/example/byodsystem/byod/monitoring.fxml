<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane minHeight="650.0" minWidth="1150.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://fxml.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.MonitoringController">
    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="20" left="15" right="15" top="20"/></padding>
            <Label text="BYOD System" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            <Region prefHeight="20.0" />
            <Button fx:id="btnDashboard" text="📊  Dashboard" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnStudents" text="👥  Students" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnDevices" text="💻  Devices" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnLogs" text="🔄  Ingress-Egress Logs" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: #89B893; -fx-text-fill: white;"/>
            <Button fx:id="btnActivity" text="📑  Recent Activity" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnReports" text="📄  Reports" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnSettings" text="⚙️  Settings" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnLogout" text="🚪  Logout" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #EF4444;"/>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="20" right="20"/></padding>
            <Label fx:id="lblDate" text="Date Placeholder" style="-fx-text-fill: #64748B;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="lblAdminName" text="Operator" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblAdminRole" text="Role" style="-fx-font-size: 10; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <VBox spacing="30.0">
            <padding><Insets bottom="30" left="30" right="30" top="30"/></padding>
            <Label text="Ingress-Egress Monitoring" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            <HBox spacing="15.0">
                <VBox prefWidth="220" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Currently Inside" style="-fx-text-fill: #64748B;"/>
                    <Label fx:id="lblInsideCount" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                </VBox>
                <VBox prefWidth="220" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Outside Campus" style="-fx-text-fill: #64748B;"/>
                    <Label fx:id="lblOutsideCount" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                </VBox>
                <VBox prefWidth="220" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Today's Entries" style="-fx-text-fill: #64748B;"/>
                    <Label fx:id="lblEntriesCount" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                </VBox>
                <VBox prefWidth="220" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Today's Exits" style="-fx-text-fill: #64748B;"/>
                    <Label fx:id="lblExitsCount" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
            <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 40;" VBox.vgrow="ALWAYS">
                <Label text="Quick Check-In / Check-Out" style="-fx-font-size: 16; -fx-font-weight: bold;"/>
                <TextField fx:id="txtSearchInput" maxWidth="500.0" prefHeight="45.0" promptText="Scan or enter Student ID / Device Serial Number..." style="-fx-alignment: center; -fx-font-size: 14;"/>
                <HBox alignment="CENTER" spacing="20.0">
                    <Button fx:id="btnCheckIn" text="➡️  Check In" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #89B893; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Button fx:id="btnCheckOut" text="⬅️  Check Out" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #FBBF24; -fx-text-fill: #1E293B; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>