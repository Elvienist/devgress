<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.fxml.com/fxml/1"
      fx:controller="com.example.byodsystem.byod.controller.AuditLogController"
      style="-fx-background-color: #f5f5f5;">

    <HBox style="-fx-background-color: white; -fx-padding: 12 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
          alignment="CENTER_LEFT" spacing="10">
        <Label text="📅" style="-fx-font-size: 14px; -fx-text-fill: #555555;"/>
        <Label fx:id="lblDate" text="" style="-fx-font-size: 13px; -fx-text-fill: #555555;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <StackPane>
            <Button style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px;" text="🔔"/>
            <Label text="•" style="-fx-text-fill: #8B0000; -fx-font-size: 18px; -fx-translate-x: 4; -fx-translate-y: -6;"/>
        </StackPane>
    </HBox>

    <VBox spacing="16" VBox.vgrow="ALWAYS" style="-fx-padding: 24;">

        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="2">
                <Label text="System Audit Trails" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                <Label text="Track all changes, administrative actions, and security status updates across the application platform."
                       style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 16; -fx-border-color: #e5e7eb; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">

            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Search Logs" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                    <TextField fx:id="txtSearch" promptText="Search operator name, identifiers..." onKeyReleased="#onSearchKeyReleased"
                               style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8 12;"/>
                </VBox>

                <VBox spacing="4" prefWidth="180">
                    <Label text="Filter by Action Type" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                    <ComboBox fx:id="cmbActionFilter" prefWidth="180" promptText="All Action Types" onAction="#onFilterChanged"
                              style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 5 8;"/>
                </VBox>

                <VBox spacing="4" prefWidth="145">
                    <Label text="Start Date" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                    <DatePicker fx:id="dpStartDate" prefWidth="145" promptText="YYYY-MM-DD" onAction="#onFilterChanged"
                                style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                </VBox>

                <VBox spacing="4" prefWidth="145">
                    <Label text="End Date" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4b5563;"/>
                    <DatePicker fx:id="dpEndDate" prefWidth="145" promptText="YYYY-MM-DD" onAction="#onFilterChanged"
                                style="-fx-background-color: #f9fafb; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                </VBox>

                <Button fx:id="btnClearDates" text="Clear Dates" prefHeight="35.0"
                        style="-fx-background-color: transparent; -fx-border-color: #d1d5db; -fx-border-radius: 6; -fx-text-fill: #4b5563; -fx-font-weight: bold; -fx-font-size: 12px; -fx-background-radius: 6; -fx-cursor: hand; -fx-padding: 0 14;"
                        onAction="#onClearDates"/>
            </HBox>

            <TableView fx:id="tblAuditLog" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-cell-border-color: transparent;"
                       fixedCellSize="48">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colTimestamp"   text="Timestamp"   prefWidth="165" minWidth="165"/>
                    <TableColumn fx:id="colOperator"    text="Operator"     prefWidth="145" minWidth="120"/>
                    <TableColumn fx:id="colRole"        text="Role"         prefWidth="95"  minWidth="80"/>
                    <TableColumn fx:id="colAction"      text="Action"       prefWidth="150" minWidth="120"/>
                    <TableColumn fx:id="colRecordType"  text="Record Type"  prefWidth="115" minWidth="100"/>
                    <TableColumn fx:id="colIdentifier"  text="Identifier"   prefWidth="165" minWidth="130"/>
                </columns>
                <placeholder>
                    <Label text="No audit records found." style="-fx-text-fill: #6b7280; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>

        </VBox>
    </VBox>
</VBox>