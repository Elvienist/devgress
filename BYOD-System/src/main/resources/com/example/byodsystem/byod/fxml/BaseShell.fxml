<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="mainContainer" prefHeight="900.0" prefWidth="1440.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.BaseShellController">
    <left>
        <VBox prefWidth="260.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 1 0 0;" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="12.0">
                    <padding>
                        <Insets left="24.0" right="24.0" />
                    </padding>
                    <children>
                        <StackPane maxHeight="40.0" maxWidth="40.0" minHeight="40.0" minWidth="40.0" style="-fx-background-color: #7A0000; -fx-background-radius: 10;">
                            <children>
                                <Label style="-fx-text-fill: #FFFFFF;" text="🛡">
                                    <font>
                                        <Font size="20.0" />
                                    </font>
                                </Label>
                            </children>
                        </StackPane>
                        <VBox alignment="CENTER_LEFT">
                            <children>
                                <Label text="Devgress" textFill="#111111">
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Label>
                                <Label text="v2.0.0" textFill="#6C757D">
                                    <font>
                                        <Font size="11.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" style="-fx-background-color: transparent; -fx-cursor: hand;" text="‹" textFill="#6C757D">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
                <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets left="16.0" right="16.0" top="20.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnSidebarDashboard" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToDashboardContent" prefHeight="44.0" text="Dashboard">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarUserManagement" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToUserManagement" prefHeight="44.0" text="User Management">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarRequests" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToRequests" prefHeight="44.0" text="Requests">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarReports" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToReports" prefHeight="44.0" text="Reports">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarAuditLog" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToAuditLog" prefHeight="44.0" text="Audit Log">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarSettings" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToSettings" prefHeight="44.0" text="Settings">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarGateScreen" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToGateScreen" prefHeight="44.0" text="Gate Screen">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarActivityLog" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToActivityLog" prefHeight="44.0" text="Activity Log">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarStudentsDevices" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToStudentsDevices" prefHeight="44.0" text="Students and Devices">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarProfile" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToProfile" prefHeight="44.0" text="Profile">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarDeviceLog" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToDeviceLog" prefHeight="44.0" text="Device Log">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarUpdateRequest" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToUpdateRequest" prefHeight="44.0" text="Update Request">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
                <VBox spacing="4.0" style="-fx-border-color: #E9ECEF; -fx-border-width: 1 0 0 0;">
                    <padding>
                        <Insets bottom="20.0" left="16.0" right="16.0" top="15.0" />
                    </padding>
                    <children>
                        <Button fx:id="btnSidebarChangePassword" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleNavigateToChangePassword" prefHeight="44.0" text="Password Change">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                        <Button fx:id="btnSidebarLogout" alignment="BASELINE_LEFT" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogout" prefHeight="44.0" text="Logout">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #F8F9FA;" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
