<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.StudentProfileRequestController">

    <top>
        <VBox spacing="0.0" style="-fx-background-color: #F8F9FA;">
            <HBox alignment="CENTER_LEFT" prefHeight="64.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #EBF0F5; -fx-border-width: 0 0 1 0;">
                <padding>
                    <Insets left="32.0" right="32.0" />
                </padding>
                <children>
                    <Label fx:id="lblHeaderDate" style="-fx-text-fill: #6B7280;" text="Monday, October 14, 2024">
                        <font><Font name="Segoe UI" size="14.0" /></font>
                    </Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <HBox alignment="CENTER" spacing="12.0">
                        <children>
                            <Label fx:id="lblHeaderInitial" alignment="CENTER" prefHeight="36.0" prefWidth="36.0" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-background-radius: 50%; -fx-font-weight: bold;" text="A" textAlignment="CENTER">
                                <font><Font name="Segoe UI" size="14.0" /></font>
                            </Label>
                            <Label fx:id="lblHeaderName" style="-fx-text-fill: #111111; -fx-font-weight: bold;" text="Administrator">
                                <font><Font name="Segoe UI" size="14.0" /></font>
                            </Label>
                        </children>
                    </HBox>
                </children>
            </HBox>
        </VBox>
    </top>

    <center>
        <HBox spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="24.0" left="32.0" right="32.0" top="24.0" />
            </padding>
            <children>

                <VBox spacing="16.0" HBox.hgrow="ALWAYS">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label style="-fx-text-fill: #111111; -fx-font-weight: bold;" text="Profile Update Requests">
                                    <font><Font name="Segoe UI Semibold" size="24.0" /></font>
                                </Label>
                                <Label style="-fx-text-fill: #6B7280;" text="Review and manage student profile modification submissions.">
                                    <font><Font name="Segoe UI" size="14.0" /></font>
                                </Label>
                            </children>
                        </VBox>

                        <HBox spacing="8.0">
                            <children>
                                <Button fx:id="btnFilterAll" mnemonicParsing="false" onAction="#handleFilterAll" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-background-radius: 20; -fx-cursor: hand; -fx-font-weight: bold;" text="All Requests">
                                    <font><Font name="Segoe UI" size="13.0" /></font>
                                    <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                                </Button>
                                <Button fx:id="btnFilterPending" mnemonicParsing="false" onAction="#handleFilterPending" style="-fx-background-color: #FEF3C7; -fx-text-fill: #92400E; -fx-background-radius: 20; -fx-cursor: hand;" text="Pending">
                                    <font><Font name="Segoe UI" size="13.0" /></font>
                                    <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                                </Button>
                                <Button fx:id="btnFilterApproved" mnemonicParsing="false" onAction="#handleFilterApproved" style="-fx-background-color: #DCFCE7; -fx-text-fill: #15803D; -fx-background-radius: 20; -fx-cursor: hand;" text="Approved">
                                    <font><Font name="Segoe UI" size="13.0" /></font>
                                    <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                                </Button>
                                <Button fx:id="btnFilterRejected" mnemonicParsing="false" onAction="#handleFilterRejected" style="-fx-background-color: #FEE2E2; -fx-text-fill: #B91C1C; -fx-background-radius: 20; -fx-cursor: hand;" text="Rejected">
                                    <font><Font name="Segoe UI" size="13.0" /></font>
                                    <padding><Insets bottom="8.0" left="16.0" right="16.0" top="8.0" /></padding>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tblRequests" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-padding: 6;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colStudent" prefWidth="180.0" text="Student" />
                                <TableColumn fx:id="colField" prefWidth="120.0" text="Field" />
                                <TableColumn fx:id="colCurrentValue" prefWidth="140.0" text="Current Value" />
                                <TableColumn fx:id="colRequestedValue" prefWidth="140.0" text="Requested Value" />
                                <TableColumn fx:id="colReason" prefWidth="160.0" text="Reason" />
                                <TableColumn fx:id="colSubmitted" prefWidth="110.0" text="Date" />
                                <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colActions" prefWidth="100.0" text="Actions" style="-fx-alignment: CENTER;" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>

                <VBox fx:id="detailPanel" managed="false" minWidth="340.0" prefWidth="340.0" spacing="18.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1;" visible="false" HBox.hgrow="NEVER">
                    <padding>
                        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                    </padding>
                    <children>
                        <Label fx:id="lblLedgerTitle" style="-fx-text-fill: #111111; -fx-font-weight: bold;" text="Confirm Transaction">
                            <font><Font name="Segoe UI Semibold" size="16.0" /></font>
                        </Label>

                        <VBox fx:id="detailContent" spacing="14.0" style="-fx-background-color: #F9FAFB; -fx-background-radius: 8; -fx-padding: 12;" />

                        <VBox fx:id="rejectResponseArea" spacing="6.0">
                            <children>
                                <Label fx:id="lblReasonTitle" style="-fx-text-fill: #374151; -fx-font-weight: bold;" text="Reason / Remarks:">
                                    <font><Font name="Segoe UI" size="12.0" /></font>
                                </Label>
                                <TextArea fx:id="taRejectResponse" prefHeight="85.0" promptText="Enter detailed remarks or grounds for this operation..." style="-fx-background-radius: 8; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-border-width: 1;" wrapText="true">
                                    <font><Font name="Segoe UI" size="13.0" /></font>
                                </TextArea>
                            </children>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS" />

                        <VBox spacing="10.0" style="-fx-border-color: #E5E7EB; -fx-border-width: 1 0 0 0; -fx-padding: 16 0 0 0;">
                            <children>
                                <HBox spacing="12.0">
                                    <children>
                                        <Button mnemonicParsing="false" onAction="#handleCancelAction" maxWidth="1.7976931348623157E308" style="-fx-background-color: #F3F4F6; -fx-text-fill: #4B5563; -fx-background-radius: 8; -fx-cursor: hand;" text="Cancel" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI" size="13.0" /></font>
                                            <padding><Insets bottom="10.0" top="10.0" /></padding>
                                        </Button>
                                        <Button fx:id="btnConfirmAction" mnemonicParsing="false" onAction="#handleConfirmAction" maxWidth="1.7976931348623157E308" style="-fx-background-color: #15803D; -fx-text-fill: #FFFFFF; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="Confirm" HBox.hgrow="ALWAYS">
                                            <font><Font name="Segoe UI" size="13.0" /></font>
                                            <padding><Insets bottom="10.0" top="10.0" /></padding>
                                        </Button>
                                    </children>
                                </HBox>
                                <Label fx:id="lblActionError" alignment="CENTER" maxWidth="1.7976931348623157E308" style="-fx-text-fill: #B91C1C; -fx-font-weight: 500;" text="" textAlignment="CENTER" wrapText="true">
                                    <font><Font name="Segoe UI" size="12.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </VBox>

            </children>
        </HBox>
    </center>
</BorderPane>