<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane minHeight="650.0" minWidth="1150.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.DashboardController">
    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="20" left="15" right="15" top="20"/></padding>
            <Label text="BYOD System" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            <Region prefHeight="20.0" />
            <Button fx:id="btnDashboard" text="📊  Dashboard" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: #89B893; -fx-text-fill: white;"/>
            <Button fx:id="btnStudents" text="👥  Students" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnDevices" text="💻  Devices" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnLogs" text="🔄  Ingress-Egress Logs" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnActivity" text="📑  Recent Activity" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnReports" text="📄  Reports" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnSettings" text="⚙️  Settings" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnLogout" text="🚪  Logout" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #EF4444;"/>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="20" right="20"/></padding>
            <Label fx:id="lblDate" text="Date Placeholder" style="-fx-text-fill: #64748B;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="lblAdminName" text="Operator" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblAdminRole" text="Role" style="-fx-font-size: 10; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <HBox spacing="20.0">
            <padding><Insets bottom="20" left="20" right="20" top="20"/></padding>
            <VBox HBox.hgrow="ALWAYS" spacing="20.0">
                <HBox spacing="15.0">
                    <VBox prefWidth="200" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label text="Registered Devices" style="-fx-text-fill: #64748B;"/>
                        <Label fx:id="lblRegisteredDevices" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox prefWidth="200" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label text="Currently Inside" style="-fx-text-fill: #64748B;"/>
                        <Label fx:id="lblCurrentlyInside" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox prefWidth="200" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label text="Today's Entries" style="-fx-text-fill: #64748B;"/>
                        <Label fx:id="lblTodayEntries" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox prefWidth="200" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                        <Label text="Today's Exits" style="-fx-text-fill: #64748B;"/>
                        <Label fx:id="lblTodayExits" text="0" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
                <VBox VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                    <Label text="Today's Entry Pattern" style="-fx-font-weight: bold;"/>
                    <LineChart fx:id="entryPatternChart" createSymbols="false" legendVisible="false">
                        <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis side="LEFT" /></yAxis>
                    </LineChart>
                </VBox>
            </VBox>
            <VBox prefWidth="300.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;">
                <Label text="Device Summary" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                <VBox spacing="5.0">
                    <HBox><Label text="Laptops Inside"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblLaptopsCount" text="0"/></HBox>
                    <ProgressBar fx:id="progressLaptops" progress="0.0" maxWidth="1.1797693134862315E308"/>
                </VBox>
                <VBox spacing="5.0">
                    <HBox><Label text="Tablets Inside"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblTabletsCount" text="0"/></HBox>
                    <ProgressBar fx:id="progressTablets" progress="0.0" maxWidth="1.1797693134862315E308"/>
                </VBox>
                <VBox spacing="5.0">
                    <HBox><Label text="Others Inside"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblOthersCount" text="0"/></HBox>
                    <ProgressBar fx:id="progressOthers" progress="0.0" maxWidth="1.1797693134862315E308"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>