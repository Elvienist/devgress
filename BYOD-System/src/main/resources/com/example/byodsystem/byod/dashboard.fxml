<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.byodsystem.byod.controller.DashboardController">

    <left>
        <VBox spacing="15"
              prefWidth="200"
              style="-fx-padding: 20; -fx-background-color: #2c3e50;">

            <Button text="Students" onAction="#openStudents" style="-fx-pref-width: 160;"/>
            <Button text="Devices" onAction="#openDevices" style="-fx-pref-width: 160;"/>
            <Button text="Monitoring" onAction="#openMonitoring" style="-fx-pref-width: 160;"/>
            <Button text="Reports" onAction="#openReports" style="-fx-pref-width: 160;"/>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="mainPane"/>
    </center>

</BorderPane>