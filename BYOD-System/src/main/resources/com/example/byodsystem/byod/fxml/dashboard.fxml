<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.byodsystem.byod.controller.DashboardController">
    <children>

        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" prefHeight="70.0"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 1 0;">
                    <padding><Insets left="30.0" right="30.0" /></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label text="📅" textFill="#6C757D"><font><Font size="14.0" /></font></Label>
                                <Label fx:id="dateLabel" textFill="#495057"><font><Font size="13.0" /></font></Label>
                            </children>
                        </HBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="20.0">
                            <children>
                                <Button mnemonicParsing="false"
                                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                                        text="🔔" textFill="#6C757D">
                                    <font><Font size="16.0" /></font>
                                </Button>
                                <HBox alignment="CENTER" spacing="10.0">
                                    <children>
                                        <VBox alignment="CENTER_RIGHT">
                                            <children>
                                                <Label fx:id="adminNameLabel" textFill="#212529">
                                                    <font><Font name="System Bold" size="13.0" /></font>
                                                </Label>
                                                <StackPane style="-fx-background-color: #7A0000; -fx-background-radius: 4;">
                                                    <padding><Insets bottom="1.0" left="6.0" right="6.0" top="1.0" /></padding>
                                                    <children>
                                                        <Label fx:id="adminRoleLabel" style="-fx-text-fill: #FFFFFF;">
                                                            <font><Font name="System Bold" size="10.0" /></font>
                                                        </Label>
                                                    </children>
                                                </StackPane>
                                            </children>
                                        </VBox>
                                        <StackPane maxHeight="40.0" maxWidth="40.0" minHeight="40.0" minWidth="40.0"
                                                   style="-fx-background-color: #7A0000; -fx-background-radius: 20;">
                                            <children>
                                                <Label fx:id="adminInitialLabel" style="-fx-text-fill: #FFFFFF;">
                                                    <font><Font name="System Bold" size="14.0" /></font>
                                                </Label>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: #F8F9FA;"
                            VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="25.0">
                            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="30.0" /></padding>
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label text="Dashboard" textFill="#111111">
                                            <font><Font name="System Bold" size="24.0" /></font>
                                        </Label>
                                        <Label fx:id="welcomeLabel" textFill="#6C757D">
                                            <font><Font size="14.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>

                                <HBox fx:id="pendingBanner" alignment="CENTER_LEFT" prefHeight="65.0"
                                      style="-fx-background-color: #FFF9E6; -fx-background-radius: 12; -fx-border-color: #FFEBAA; -fx-border-radius: 12;">
                                    <padding><Insets left="20.0" right="20.0" /></padding>
                                    <children>
                                        <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0"
                                                   style="-fx-background-color: #F59E0B; -fx-background-radius: 18;">
                                            <children>
                                                <Label style="-fx-text-fill: #FFFFFF;" text="🔔">
                                                    <font><Font size="14.0" /></font>
                                                </Label>
                                            </children>
                                        </StackPane>
                                        <VBox alignment="CENTER_LEFT" spacing="2.0">
                                            <HBox.margin><Insets left="15.0" /></HBox.margin>
                                            <children>
                                                <Label text="Pending Profile Update Requests" textFill="#1F2937">
                                                    <font><Font name="System Bold" size="14.0" /></font>
                                                </Label>
                                                <Label fx:id="pendingCountLabel" textFill="#4B5563">
                                                    <font><Font size="13.0" /></font>
                                                </Label>
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button mnemonicParsing="false" onAction="#handleReviewRequests"
                                                prefHeight="34.0" prefWidth="105.0"
                                                style="-fx-background-color: #F59E0B; -fx-background-radius: 8; -fx-cursor: hand;"
                                                text="Review Now" textFill="#1F2937">
                                            <font><Font name="System Bold" size="13.0" /></font>
                                        </Button>
                                        <Button mnemonicParsing="false" onAction="#handleDismissBanner"
                                                style="-fx-background-color: transparent; -fx-cursor: hand;"
                                                text="✕" textFill="#9CA3AF">
                                            <font><Font size="14.0" /></font>
                                            <HBox.margin><Insets left="15.0" /></HBox.margin>
                                        </Button>
                                    </children>
                                </HBox>

                                <TextField fx:id="searchField" onAction="#handleSearch" prefHeight="48.0"
                                           promptText="Search students, devices, or logs..."
                                           style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 16 0 16; -fx-text-fill: #1F2937;">
                                    <font><Font size="14.0" /></font>
                                </TextField>

                                <HBox spacing="16.0">
                                    <children>
                                        <VBox prefHeight="120.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                                            <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0" style="-fx-background-color: #7A0000; -fx-background-radius: 8;">
                                                            <children><Label style="-fx-text-fill: #FFFFFF;" text="👥" /></children>
                                                        </StackPane>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="studentsTrendLabel" textFill="#10B981"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <Region VBox.vgrow="ALWAYS" />
                                                <Label fx:id="totalStudentsLabel" textFill="#111111"><font><Font name="System Bold" size="24.0" /></font></Label>
                                                <Label text="Total Students" textFill="#6C757D"><font><Font size="13.0" /></font></Label>
                                            </children>
                                        </VBox>

                                        <VBox prefHeight="120.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                                            <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0" style="-fx-background-color: #D97706; -fx-background-radius: 8;">
                                                            <children><Label style="-fx-text-fill: #FFFFFF;" text="💻" /></children>
                                                        </StackPane>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="devicesTrendLabel" textFill="#10B981"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <Region VBox.vgrow="ALWAYS" />
                                                <Label fx:id="totalDevicesLabel" textFill="#111111"><font><Font name="System Bold" size="24.0" /></font></Label>
                                                <Label text="Total Devices" textFill="#6C757D"><font><Font size="13.0" /></font></Label>
                                            </children>
                                        </VBox>

                                        <VBox prefHeight="120.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                                            <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0" style="-fx-background-color: #059669; -fx-background-radius: 8;">
                                                            <children><Label style="-fx-text-fill: #FFFFFF;" text="➔" /></children>
                                                        </StackPane>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="insideTrendLabel" textFill="#6C757D"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <Region VBox.vgrow="ALWAYS" />
                                                <Label fx:id="devicesInsideLabel" textFill="#111111"><font><Font name="System Bold" size="24.0" /></font></Label>
                                                <Label text="Devices Inside" textFill="#6C757D"><font><Font size="13.0" /></font></Label>
                                            </children>
                                        </VBox>

                                        <VBox prefHeight="120.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                                            <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0" style="-fx-background-color: #2563EB; -fx-background-radius: 8;">
                                                            <children><Label style="-fx-text-fill: #FFFFFF;" text="📈" /></children>
                                                        </StackPane>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="entriesTodayTrendLabel" textFill="#10B981"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <Region VBox.vgrow="ALWAYS" />
                                                <Label fx:id="todayEntriesLabel" textFill="#111111"><font><Font name="System Bold" size="24.0" /></font></Label>
                                                <Label text="Today's Entries" textFill="#6C757D"><font><Font size="13.0" /></font></Label>
                                            </children>
                                        </VBox>

                                        <VBox prefHeight="120.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                                            <padding><Insets bottom="16.0" left="20.0" right="20.0" top="16.0" /></padding>
                                            <children>
                                                <HBox alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0" style="-fx-background-color: #EA580C; -fx-background-radius: 8;">
                                                            <children><Label style="-fx-text-fill: #FFFFFF;" text="⬅" /></children>
                                                        </StackPane>
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label fx:id="exitsTodayTrendLabel" textFill="#10B981"><font><Font name="System Bold" size="12.0" /></font></Label>
                                                    </children>
                                                </HBox>
                                                <Region VBox.vgrow="ALWAYS" />
                                                <Label fx:id="todayExitsLabel" textFill="#111111"><font><Font name="System Bold" size="24.0" /></font></Label>
                                                <Label text="Today's Exits" textFill="#6C757D"><font><Font size="13.0" /></font></Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="20.0">
                                    <children>
                                        <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;" HBox.hgrow="ALWAYS">
                                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                                            <children>
                                                <Label text="Today's Entry Pattern" textFill="#111111"><font><Font name="System Bold" size="16.0" /></font></Label>
                                                <BarChart fx:id="entryPatternChart" horizontalGridLinesVisible="false" legendVisible="false" prefHeight="320.0" verticalGridLinesVisible="false">
                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                    <VBox.margin><Insets top="15.0" /></VBox.margin>
                                                </BarChart>
                                            </children>
                                        </VBox>

                                        <VBox prefWidth="360.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12;">
                                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                                            <children>
                                                <Label text="Device Breakdown" textFill="#111111"><font><Font name="System Bold" size="16.0" /></font></Label>
                                                <VBox spacing="16.0">
                                                    <VBox.margin><Insets top="25.0" /></VBox.margin>
                                                    <children>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="Laptops" textFill="#495057"><font><Font size="13.0" /></font></Label>
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Label fx:id="laptopsCountLabel" textFill="#212529"><font><Font name="System Bold" size="13.0" /></font></Label>
                                                                    </children>
                                                                </HBox>
                                                                <ProgressBar fx:id="laptopsBar" maxWidth="1.7976931348623157E308" prefHeight="8.0" progress="0" style="-fx-accent: #7A0000; -fx-control-inner-background: #F1F3F5;" />
                                                                <Label fx:id="laptopsPctLabel" textFill="#868E96"><font><Font size="11.0" /></font></Label>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="Tablets" textFill="#495057"><font><Font size="13.0" /></font></Label>
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Label fx:id="tabletsCountLabel" textFill="#212529"><font><Font name="System Bold" size="13.0" /></font></Label>
                                                                    </children>
                                                                </HBox>
                                                                <ProgressBar fx:id="tabletsBar" maxWidth="1.7976931348623157E308" prefHeight="8.0" progress="0" style="-fx-accent: #D97706; -fx-control-inner-background: #F1F3F5;" />
                                                                <Label fx:id="tabletsPctLabel" textFill="#868E96"><font><Font size="11.0" /></font></Label>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="Phones" textFill="#495057"><font><Font size="13.0" /></font></Label>
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Label fx:id="phonesCountLabel" textFill="#212529"><font><Font name="System Bold" size="13.0" /></font></Label>
                                                                    </children>
                                                                </HBox>
                                                                <ProgressBar fx:id="phonesBar" maxWidth="1.7976931348623157E308" prefHeight="8.0" progress="0" style="-fx-accent: #2563EB; -fx-control-inner-background: #F1F3F5;" />
                                                                <Label fx:id="phonesPctLabel" textFill="#868E96"><font><Font size="11.0" /></font></Label>
                                                            </children>
                                                        </VBox>
                                                        <VBox spacing="6.0">
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT">
                                                                    <children>
                                                                        <Label text="Others" textFill="#495057"><font><Font size="13.0" /></font></Label>
                                                                        <Region HBox.hgrow="ALWAYS" />
                                                                        <Label fx:id="othersCountLabel" textFill="#212529"><font><Font name="System Bold" size="13.0" /></font></Label>
                                                                    </children>
                                                                </HBox>
                                                                <ProgressBar fx:id="othersBar" maxWidth="1.7976931348623157E308" prefHeight="8.0" progress="0" style="-fx-accent: #CED4DA; -fx-control-inner-background: #F1F3F5;" />
                                                                <Label fx:id="othersPctLabel" textFill="#868E96"><font><Font size="11.0" /></font></Label>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>

        <StackPane fx:id="reviewOverlay" alignment="CENTER" managed="false" visible="false"
                   style="-fx-background-color: rgba(0,0,0,0.45);">
            <VBox prefWidth="540.0" minWidth="540.0" maxWidth="540.0" maxHeight="-Infinity" spacing="0.0"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 12, 0, 0, 4);">
                <children>

                    <HBox alignment="CENTER_LEFT" prefHeight="54.0"
                          style="-fx-border-color: #E9ECEF; -fx-border-width: 0 0 1 0;">
                        <padding><Insets left="24.0" right="20.0" /></padding>
                        <children>
                            <Label fx:id="overlayTitleLabel" text="Review Profile Update Request" textFill="#7A0000">
                                <font><Font name="System Bold" size="15.0" /></font>
                            </Label>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="overlayCounterLabel" textFill="#6C757D">
                                <font><Font size="12.0" /></font>
                            </Label>
                            <Button mnemonicParsing="false" onAction="#handleOverlayClose"
                                    style="-fx-background-color: transparent; -fx-cursor: hand;" text="✕" textFill="#6C757D">
                                <font><Font size="15.0" /></font>
                                <HBox.margin><Insets left="14.0" /></HBox.margin>
                            </Button>
                        </children>
                    </HBox>

                    <VBox spacing="12.0">
                        <padding><Insets bottom="16.0" left="24.0" right="24.0" top="14.0" /></padding>
                        <children>
                            <VBox spacing="2.0">
                                <children>
                                    <Label text="Student" textFill="#6C757D"><font><Font size="11.0" /></font></Label>
                                    <Label fx:id="overlayStudentNameLabel" textFill="#212529"><font><Font name="System Bold" size="15.0" /></font></Label>
                                </children>
                            </VBox>

                            <VBox spacing="4.0">
                                <children>
                                    <Label text="Field to Update" textFill="#495057"><font><Font size="11.0" /></font></Label>
                                    <TextField fx:id="overlayFieldLabel" editable="false" prefHeight="36.0"
                                               style="-fx-background-color: #F8F9FA; -fx-border-color: #E5E7EB; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 12 0 12; -fx-text-fill: #495057;">
                                        <font><Font size="13.0" /></font>
                                    </TextField>
                                </children>
                            </VBox>

                            <HBox spacing="12.0">
                                <children>
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="Current Value" textFill="#495057"><font><Font size="11.0" /></font></Label>
                                            <TextField fx:id="overlayCurrentLabel" editable="false" prefHeight="36.0"
                                                       style="-fx-background-color: #F8F9FA; -fx-border-color: #E5E7EB; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 12 0 12; -fx-text-fill: #6C757D;">
                                                <font><Font size="13.0" /></font>
                                            </TextField>
                                        </children>
                                    </VBox>
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label text="Requested Value" textFill="#495057"><font><Font size="11.0" /></font></Label>
                                            <TextField fx:id="overlayRequestedLabel" editable="false" prefHeight="36.0"
                                                       style="-fx-background-color: #F8F9FA; -fx-border-color: #E5E7EB; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 12 0 12; -fx-text-fill: #212529;">
                                                <font><Font name="System Bold" size="13.0" /></font>
                                            </TextField>
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="4.0">
                                <children>
                                    <Label text="Reason for Update" textFill="#495057"><font><Font size="11.0" /></font></Label>
                                    <TextArea fx:id="overlayReasonArea" editable="false" prefHeight="50.0" wrapText="true"
                                              style="-fx-background-color: transparent; -fx-control-inner-background: #F8F9FA; -fx-text-fill: #495057; -fx-border-color: #E5E7EB; -fx-border-radius: 6; -fx-background-radius: 6;">
                                        <font><Font size="13.0" /></font>
                                    </TextArea>
                                </children>
                            </VBox>

                            <VBox fx:id="rejectReasonBox" spacing="4.0" managed="false" visible="false">
                                <children>
                                    <Label text="Specify Rejection Reason" textFill="#DC2626"><font><Font size="11.0" /></font></Label>
                                    <TextField fx:id="rejectReasonField" prefHeight="36.0" promptText="Enter reason for rejection..."
                                               style="-fx-background-color: #FFFFFF; -fx-border-color: #FCA5A5; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0 12 0 12; -fx-text-fill: #212529;">
                                        <font><Font size="13.0" /></font>
                                    </TextField>
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <HBox alignment="CENTER_RIGHT" spacing="10.0"
                          style="-fx-border-color: #E9ECEF; -fx-border-width: 1 0 0 0;">
                        <padding><Insets bottom="14.0" left="24.0" right="24.0" top="14.0" /></padding>
                        <children>
                            <Button mnemonicParsing="false" onAction="#handleOverlaySkip" prefHeight="32.0" prefWidth="70.0"
                                    style="-fx-background-color: #F8F9FA; -fx-background-radius: 6; -fx-border-color: #DEE2E6; -fx-border-radius: 6; -fx-cursor: hand;"
                                    text="Skip" textFill="#495057">
                                <font><Font size="12.0" /></font>
                            </Button>
                            <Button fx:id="overlayRejectBtn" mnemonicParsing="false" onAction="#handleOverlayReject" prefHeight="32.0" prefWidth="110.0"
                                    style="-fx-background-color: #FFFFFF; -fx-background-radius: 6; -fx-border-color: #DC2626; -fx-border-radius: 6; -fx-cursor: hand;"
                                    text="Reject" textFill="#DC2626">
                                <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                            <Button mnemonicParsing="false" onAction="#handleOverlayApprove" prefHeight="32.0" prefWidth="95.0"
                                    style="-fx-background-color: #7A0000; -fx-background-radius: 6; -fx-cursor: hand;"
                                    text="Approve" textFill="#FFFFFF">
                                <font><Font name="System Bold" size="12.0" /></font>
                            </Button>
                        </children>
                    </HBox>

                </children>
            </VBox>
        </StackPane>

    </children>
</StackPane>