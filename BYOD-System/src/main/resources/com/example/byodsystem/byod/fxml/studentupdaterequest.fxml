<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" focusTraversable="false" hbarPolicy="NEVER" style="-fx-background-color: #F8F9FA; -fx-background: #F8F9FA; -fx-padding: 0;" stylesheets="@../css/studentupdaterequest.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.StudentUpdateRequestController">
    <content>
        <VBox spacing="24.0" style="-fx-background-color: #F8F9FA;">
            <padding><Insets bottom="32.0" left="32.0" right="32.0" top="0.0" /></padding>

            <HBox alignment="CENTER_LEFT" prefHeight="64.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #EBF0F5; -fx-border-width: 0 0 1 0;">
                <padding><Insets left="32.0" right="32.0" /></padding>
                <Label fx:id="lblHeaderDate" style="-fx-text-fill: #6C757D; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Inter, sans-serif;" text="Monday, October 14, 2024" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="16.0">
                    <Label style="-fx-text-fill: #9A3412; -fx-background-color: #FFEDD5; -fx-background-radius: 20; -fx-font-size: 11px; -fx-font-weight: bold; -fx-font-family: 'Segoe UI', Inter; -fx-padding: 4 12 4 12;" text="Student View" />
                    <HBox alignment="CENTER" spacing="10.0">
                        <StackPane style="-fx-background-color: #7A0000; -fx-background-radius: 18; -fx-min-width: 36; -fx-min-height: 36; -fx-max-width: 36; -fx-max-height: 36;">
                            <Label fx:id="lblHeaderInitial" style="-fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', Inter;" text="K" />
                        </StackPane>
                        <VBox alignment="CENTER_LEFT">
                            <Label fx:id="lblHeaderName" style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Inter;" text="Kirby Torres" />
                            <Label style="-fx-text-fill: #6C757D; -fx-font-size: 11px; -fx-font-family: 'Segoe UI', Inter;" text="Student" />
                        </VBox>
                    </HBox>
                </HBox>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="8.0">
                    <Label style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 24px; -fx-font-family: 'Segoe UI', Arial;" text="Profile Information Update Request" />
                    <Label style="-fx-text-fill: #6B7280; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', Arial;" text="Submit a dynamic request to change your registered information. All changes pass through administrator evaluation." />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnReturnToProfile" mnemonicParsing="false" onAction="#handleReturnToProfile" style="-fx-background-color: #FFFFFF; -fx-text-fill: #374151; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;" text="← Return to Profile">
                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                </Button>
            </HBox>

            <VBox spacing="24.0">
                <VBox spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #EBF0F5; -fx-border-width: 1; -fx-border-radius: 12;">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>

                    <HBox spacing="16.0">
                        <VBox spacing="6.0">
                            <Label style="-fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="Select Field to Update" />
                            <ComboBox fx:id="cbField" onAction="#handleFieldChange" prefHeight="40.0" prefWidth="240.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-radius: 6;" />
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label style="-fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="Current Value" />
                            <TextField fx:id="tfCurrentValue" editable="false" prefHeight="40.0" style="-fx-background-color: #F3F4F6; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-radius: 6; -fx-text-fill: #6B7280;" />
                        </VBox>
                    </HBox>

                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="New Value to Commit" />
                        <StackPane alignment="CENTER_LEFT">
                            <TextField fx:id="tfNewValue" prefHeight="40.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-radius: 6;" />
                            <ComboBox fx:id="cbYearLevelOptions" maxWidth="1.7976931348623157E308" prefHeight="40.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-radius: 6;" visible="false" />
                        </StackPane>
                    </VBox>

                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #374151; -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="Reason for Request" />
                        <TextArea fx:id="taReason" prefHeight="100.0" promptText="Please provide a clear and detailed explanation for this change..." style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 6; -fx-background-radius: 6;" wrapText="true" />
                    </VBox>

                    <HBox alignment="CENTER_LEFT">
                        <Label fx:id="lblFormError" style="-fx-text-fill: #B91C1C; -fx-font-weight: bold;" wrapText="true" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnSubmit" mnemonicParsing="false" onAction="#handleSubmit" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;" text="Submit Dynamic Request">
                            <padding><Insets bottom="10.0" left="24.0" right="24.0" top="10.0" /></padding>
                        </Button>
                    </HBox>
                </VBox>

                <VBox spacing="16.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #EBF0F5; -fx-border-width: 1; -fx-border-radius: 12;">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="16.0">
                        <VBox spacing="4.0">
                            <Label style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 16px; -fx-font-family: 'Segoe UI', Arial;" text="Historic Submission Log" />
                            <Label style="-fx-text-fill: #6C757D; -fx-font-size: 13px;" text="Track and filter the state of your submitted profile updates." />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="8.0">
                            <Button fx:id="btnFilterAll" onAction="#handleFilterAll" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 12px;" text="All" />
                            <Button fx:id="btnFilterPending" onAction="#handleFilterPending" style="-fx-background-color: #FEF3C7; -fx-text-fill: #92400E; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 12px;" text="Pending" />
                            <Button fx:id="btnFilterApproved" onAction="#handleFilterApproved" style="-fx-background-color: #DCFCE7; -fx-text-fill: #15803D; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 12px;" text="Approved" />
                            <Button fx:id="btnFilterRejected" onAction="#handleFilterRejected" style="-fx-background-color: #FEE2E2; -fx-text-fill: #B91C1C; -fx-background-radius: 20; -fx-padding: 6 14; -fx-font-weight: bold; -fx-cursor: hand; -fx-font-size: 12px;" text="Rejected" />
                        </HBox>
                    </HBox>

                    <ScrollPane fitToWidth="true" focusTraversable="false" hbarPolicy="NEVER" maxWidth="1.7976931348623157E308" maxHeight="420.0" prefHeight="420.0" style="-fx-background-color: transparent; -fx-background: #FFFFFF; -fx-border-color: #EBF0F5; -fx-border-width: 1 0 0 0; -fx-padding: 12 0 0 0;">
                        <content>
                            <VBox fx:id="pastRequestsContainer" focusTraversable="false" spacing="12.0" style="-fx-background-color: #FFFFFF;" />
                        </content>
                    </ScrollPane>
                </VBox>
            </VBox>
        </VBox>
    </content>
</ScrollPane>