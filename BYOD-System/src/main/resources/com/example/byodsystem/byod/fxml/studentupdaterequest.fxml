<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #F8F9FA; -fx-background: #F8F9FA; -fx-padding: 0;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.StudentUpdateRequestController">
    <content>
        <VBox style="-fx-background-color: #F8F9FA;">

            <HBox alignment="CENTER_LEFT" prefHeight="64.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #EBF0F5; -fx-border-width: 0 0 1 0;">
                <padding><Insets left="32.0" right="32.0" /></padding>
                <Label fx:id="lblHeaderDate" style="-fx-text-fill: #6C757D; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="Monday, June 15, 2026" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="12.0">
                    <StackPane maxHeight="36.0" maxWidth="36.0" minHeight="36.0" minWidth="36.0" style="-fx-background-color: #7A0000; -fx-background-radius: 18;">
                        <Label fx:id="lblHeaderInitial" style="-fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-font-size: 14px; -fx-font-family: 'Segoe UI', Arial;" text="S" />
                    </StackPane>
                    <VBox alignment="CENTER_LEFT">
                        <Label fx:id="lblHeaderName" style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="Student" />
                        <HBox alignment="CENTER_LEFT" spacing="6.0">
                            <Label style="-fx-text-fill: #7A0000; -fx-background-color: #FFF1F1; -fx-background-radius: 4; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 2 6 2 6; -fx-font-family: 'Segoe UI', Arial;" text="Student View" />
                        </HBox>
                    </VBox>
                </HBox>
            </HBox>

            <VBox spacing="24.0">
                <padding><Insets bottom="32.0" left="32.0" right="32.0" top="32.0" /></padding>

                <VBox spacing="4.0">
                    <Label style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 24px; -fx-font-family: 'Segoe UI', Arial;" text="Profile Update Center" />
                    <Label style="-fx-text-fill: #6C757D; -fx-font-size: 13px; -fx-font-family: 'Segoe UI', Arial;" text="Submit secure documentation amendments or track your historic modification requests." />
                </VBox>

                <VBox spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #EBF0F5; -fx-border-width: 1; -fx-border-radius: 12;">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>

                    <Label style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 16px; -fx-font-family: 'Segoe UI', Arial;" text="Create New Information Request" />

                    <HBox spacing="16.0">
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS" prefWidth="0.0">
                            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold; -fx-font-size: 11px; -fx-font-family: 'Segoe UI', Arial;" text="FIELD TARGET FOR MODIFICATION" />
                            <ComboBox fx:id="cbField" maxWidth="1.7976931348623157E308" onAction="#handleFieldSelected" promptText="Select profile field..." style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-padding: 6 8 6 8; -fx-font-size: 13px;" />
                        </VBox>
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS" prefWidth="0.0">
                            <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold; -fx-font-size: 11px; -fx-font-family: 'Segoe UI', Arial;" text="CURRENT STORED VALUE" />
                            <TextField fx:id="tfCurrentValue" editable="false" style="-fx-background-color: #F3F4F6; -fx-background-radius: 8; -fx-border-color: #EBF0F5; -fx-border-radius: 8; -fx-text-fill: #6B7280; -fx-padding: 10 12 10 12; -fx-font-size: 13px;" text="—" />
                        </VBox>
                    </HBox>

                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold; -fx-font-size: 11px; -fx-font-family: 'Segoe UI', Arial;" text="PROPOSED NEW VALUE" />
                        <StackPane alignment="CENTER_LEFT">
                            <TextField fx:id="tfNewValue" promptText="Enter requested changes..." style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-padding: 10 12 10 12; -fx-font-size: 13px;" />
                            <ComboBox fx:id="cbYearLevelOptions" maxWidth="1.7976931348623157E308" promptText="Select preferred year placement..." style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-padding: 8 12 8 12; -fx-font-size: 13px;" visible="false" />
                        </StackPane>
                    </VBox>

                    <VBox spacing="6.0">
                        <Label style="-fx-text-fill: #4B5563; -fx-font-weight: bold; -fx-font-size: 11px; -fx-font-family: 'Segoe UI', Arial;" text="JUSTIFICATION / REASON" />
                        <TextArea fx:id="taReason" prefHeight="85.0" promptText="Provide a clear explanation for why this administrative profile change is necessary..." style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-font-size: 13px; -fx-text-fill: #111111;" wrapText="true" />
                    </VBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                        <Label fx:id="lblFormError" style="-fx-text-fill: #DC2626; -fx-font-size: 12px; -fx-font-weight: bold;" text="" wrapText="true" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnSubmit" mnemonicParsing="false" onAction="#handleSubmit" style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 13px;" text="Submit Dynamic Request">
                            <padding><Insets bottom="10.0" left="24.0" right="24.0" top="10.0" /></padding>
                        </Button>
                    </HBox>
                </VBox>

                <VBox spacing="16.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-border-color: #EBF0F5; -fx-border-width: 1; -fx-border-radius: 12;">
                    <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>

                    <VBox spacing="4.0">
                        <Label style="-fx-text-fill: #111111; -fx-font-weight: bold; -fx-font-size: 16px; -fx-font-family: 'Segoe UI', Arial;" text="Historic Submission Log" />
                        <Label style="-fx-text-fill: #6C757D; -fx-font-size: 12px; -fx-font-family: 'Segoe UI', Arial;" text="A detailed real-time registry of modifications pending administrative intervention." />
                    </VBox>

                    <VBox fx:id="pastRequestsContainer" spacing="12.0" />
                </VBox>

            </VBox>
        </VBox>
    </content>
</ScrollPane>