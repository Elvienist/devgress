<!-- Top Screen Header Title Section -->
<VBox spacing="6.0">
    <Label style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0F172A;" text="Students &amp; Devices" />
    <Label style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 14px; -fx-text-fill: #64748B;" text="Manage student records and registered devices" />
</VBox>

<!-- Navigation / View Toggle Group -->
<HBox alignment="CENTER_LEFT" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="8.0" left="12.0" right="12.0" top="8.0" />
    </padding>
    <HBox spacing="10.0" styleClass="segmented-bar">
        <ToggleButton fx:id="btnStudentsToggle" selected="true" style="-fx-background-color: #8B1D1D; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;" text="Students">
            <toggleGroup>
                <ToggleGroup fx:id="viewToggleGroup" />
            </toggleGroup>
            <padding>
                <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
            </padding>
        </ToggleButton>
        <ToggleButton fx:id="btnDevicesToggle" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand;" text="Devices" toggleGroup="$viewToggleGroup">
            <padding>
                <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
            </padding>
        </ToggleButton>
    </HBox>
</HBox>

<!-- Main Content Area: Splits Table and Inline Form Panel Side-by-Side -->
<HBox spacing="20.0" VBox.vgrow="ALWAYS">
    
    <!-- Left Side: Search Controls & Data Table Container -->
    <VBox spacing="16.0" HBox.hgrow="ALWAYS">
        
        <!-- Controls Bar: Search, Status Filter, and Action button -->
        <HBox alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
            <padding>
                <Insets bottom="12.0" left="16.0" right="16.0" top="12.0" />
            </padding>
            
            <!-- Search bar (Expands to occupy unused horizontal space) -->
            <TextField fx:id="txtSearch" promptText="Search students..." style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-font-size: 14px;" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
                </padding>
            </TextField>
            
            <!-- Active/Inactive Filter Segment -->
            <HBox spacing="4.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8px; -fx-padding: 4px;">
                <ToggleButton fx:id="btnFilterActive" selected="true" style="-fx-background-color: #E2E8F0; -fx-text-fill: #1E293B; -fx-font-weight: bold; -fx-background-radius: 6px;" text="Active">
                    <toggleGroup>
                        <ToggleGroup fx:id="statusFilterGroup" />
                    </toggleGroup>
                    <padding>
                        <Insets bottom="6.0" left="12.0" right="12.0" top="6.0" />
                    </padding>
                </ToggleButton>
                <ToggleButton fx:id="btnFilterInactive" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-background-radius: 6px;" text="Inactive" toggleGroup="$statusFilterGroup">
                    <padding>
                        <Insets bottom="6.0" left="12.0" right="12.0" top="6.0" />
                    </padding>
                </ToggleButton>
            </HBox>
            
            <!-- Prominent Add New Button -->
            <Button fx:id="btnAddNew" graphicTextGap="6.0" style="-fx-background-color: #8B1D1D; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-font-size: 14px; -fx-cursor: hand;" text="+ Add New">
                <padding>
                    <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                </padding>
            </Button>
        </HBox>

        <!-- Table View: Managed dynamically inside the controller depending on toggle status -->
        <TableView fx:id="tblMain" style="-fx-background-radius: 12px; -fx-border-radius: 12px; -fx-border-color: #E2E8F0;" VBox.vgrow="ALWAYS">
            <columns>
                <!-- Core columns setup for Students default view -->
                <TableColumn fx:id="colId" prefWidth="130.0" text="Student ID" />
                <TableColumn fx:id="colName" prefWidth="200.0" text="Name" />
                <TableColumn fx:id="colCourse" prefWidth="180.0" text="Course" />
                <TableColumn fx:id="colYear" prefWidth="120.0" text="Year" />
                <TableColumn fx:id="colDevices" prefWidth="100.0" text="Devices" />
                <TableColumn fx:id="colStatus" prefWidth="110.0" text="Status" />
                <TableColumn fx:id="colActions" prefWidth="130.0" text="Actions" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <!-- Right Side: Inline Form Panel (Becomes visible dynamically during add/edit phases) -->
    <VBox fx:id="pnlInlineForm" managed="false" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;" visible="false" HBox.hgrow="NEVER">
        <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
        </padding>
        <prefWidth>420.0</prefWidth>
        
        <HBox alignment="CENTER_LEFT" style="-fx-border-color: #F1F5F9; -fx-border-width: 0 0 1px 0;">
            <padding>
                <Insets bottom="12.0" />
            </padding>
            <Label fx:id="lblFormTitle" style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Add New Record" />
        </HBox>

        <GridPane hgap="12.0" vgap="16.0">
            <columnConstraints>
                <ColumnConstraints hgrow="NEVER" minWidth="100.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            
            <!-- Form Inputs populated dynamically by controller context -->
            <Label style="-fx-text-fill: #64748B; -fx-font-weight: bold;" text="ID *" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtFormId" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            
            <Label style="-fx-text-fill: #64748B; -fx-font-weight: bold;" text="Primary Field *" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtFormPrimary" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            
            <Label style="-fx-text-fill: #64748B; -fx-font-weight: bold;" text="Secondary Field" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txtFormSecondary" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6px;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            
            <Label style="-fx-text-fill: #64748B; -fx-font-weight: bold;" text="Third Field" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="txtFormTertiary" style="-fx-background-color: #F8FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 6px;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        <rowConstraints>
           <RowConstraints />
           <RowConstraints />
           <RowConstraints />
           <RowConstraints />
        </rowConstraints>
        </GridPane>

        <!-- Inline Panel Save / Dismiss Actions -->
        <HBox alignment="CENTER_RIGHT" spacing="12.0">
            <padding>
                <Insets top="10.0" />
            </padding>
            <Button fx:id="btnFormCancel" style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancel">
                <padding>
                    <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
                </padding>
            </Button>
            <Button fx:id="btnFormSave" style="-fx-background-color: #8B1D1D; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;" text="Save">
                <padding>
                    <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                </padding>
            </Button>
        </HBox>
    </VBox>
</HBox>
