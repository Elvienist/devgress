<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane minHeight="650.0" minWidth="1150.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.ReportController">
    <left>
        <VBox prefWidth="220.0" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 1 0 0;">
            <padding><Insets bottom="20" left="15" right="15" top="20"/></padding>
            <Label text="BYOD System" style="-fx-font-weight: bold; -fx-font-size: 16;"/>
            <Region prefHeight="20.0" />
            <Button fx:id="btnDashboard" text="📊  Dashboard" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnStudents" text="👥  Students" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnDevices" text="💻  Devices" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnLogs" text="🔄  Ingress-Egress Logs" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnActivity" text="📑  Recent Activity" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: #89B893; -fx-text-fill: white;"/>
            <Button fx:id="btnReports" text="📄  Reports" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Button fx:id="btnSettings" text="⚙️  Settings" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #64748B;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="btnLogout" text="🚪  Logout" maxWidth="1.1797693134862315E308" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #EF4444;"/>
        </VBox>
    </left>
    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="20" right="20"/></padding>
            <Label fx:id="lblDate" text="Date Placeholder" style="-fx-text-fill: #64748B;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT">
                <Label fx:id="lblAdminName" text="Operator" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblAdminRole" text="Role" style="-fx-font-size: 10; -fx-text-fill: #94A3B8;"/>
            </VBox>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Recent System Activity Tracker">
                    <content>
                        <VBox spacing="15.0" style="-fx-padding: 20;">
                            <Label text="Complete History of Device Movements" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                            <TableView fx:id="tblActivityLogs" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colLogDetails" text="Activity Log Metadata Entry" prefWidth="450"/>
                                    <TableColumn fx:id="colLogTime" text="Timestamp Context" prefWidth="250"/>
                                    <TableColumn fx:id="colLogDirection" text="Direction" prefWidth="180"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
                <Tab text="System Reports Ledger">
                    <content>
                        <VBox spacing="15.0" style="-fx-padding: 20;">
                            <HBox spacing="15.0" alignment="CENTER_LEFT">
                                <ComboBox fx:id="cmbReportType" promptText="Select Report Blueprint Profile"/>
                                <Button fx:id="btnGenerateReport" text="Execute Report Compilation" style="-fx-background-color: #89B893; -fx-text-fill: white;"/>
                            </HBox>
                            <TableView fx:id="tblReports" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colRepTitle" text="Report Ledger Title" prefWidth="220"/>
                                    <TableColumn fx:id="colRepType" text="Classification Type" prefWidth="150"/>
                                    <TableColumn fx:id="colRepBy" text="Generated By" prefWidth="140"/>
                                    <TableColumn fx:id="colRepRange" text="Date Scope Bound" prefWidth="160"/>
                                    <TableColumn fx:id="colRepRecords" text="Processed Records" prefWidth="120"/>
                                    <TableColumn fx:id="colRepDate" text="Compiled Timestamp" prefWidth="140"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
