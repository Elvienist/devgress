<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.byodsystem.byod.controller.ReportsController"
      style="-fx-background-color: #F8F9FA;"
      prefHeight="768.0" prefWidth="1024.0">

    <HBox style="-fx-background-color: #FFFFFF; -fx-padding: 12 30; -fx-border-color: #E9ECEF; -fx-border-width: 0 0 1 0;" alignment="CENTER_LEFT" spacing="12">
        <Label text="📅" style="-fx-font-size: 15px; -fx-text-fill: #495057;"/>
        <Label fx:id="lblDate" style="-fx-font-size: 13px; -fx-text-fill: #495057; -fx-font-weight: 500;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <StackPane style="-fx-padding: 0 10 0 0;">
            <Button style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 16px; -fx-text-fill: #495057;" text="🔔"/>
            <Label text="•" style="-fx-text-fill: #7A0000; -fx-font-size: 20px;" StackPane.alignment="TOP_RIGHT" translateX="2" translateY="-6"/>
        </StackPane>
        <HBox alignment="CENTER" spacing="10">
            <VBox alignment="CENTER_RIGHT" spacing="2">
                <Label text="Administrator" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>
                <Label text="Admin" style="-fx-background-color: #7A0000; -fx-text-fill: white; -fx-font-size: 9px; -fx-font-weight: bold; -fx-padding: 2 6; -fx-background-radius: 4;"/>
            </VBox>
            <VBox alignment="CENTER" style="-fx-background-color: #7A0000; -fx-min-width: 36px; -fx-min-height: 36px; -fx-max-width: 36px; -fx-max-height: 36px; -fx-background-radius: 18;">
                <Label text="A" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: #F8F9FA; -fx-background: #F8F9FA; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="25" style="-fx-padding: 30 30 40 30;">

            <VBox spacing="4">
                <Label text="Reports" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529; -fx-font-family: 'System'; margin: 0;"/>
                <Label text="Generate and export system reports" style="-fx-font-size: 13px; -fx-text-fill: #6C757D;"/>
            </VBox>

            <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #E9ECEF; -fx-border-radius: 8; -fx-padding: 24;" spacing="18">
                <Label text="Generate New Report" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>

                <HBox spacing="20" alignment="TOP_LEFT">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Report Type" style="-fx-font-size: 12px; -fx-font-weight: 500; -fx-text-fill: #495057;"/>
                        <ComboBox fx:id="cmbReportType" maxWidth="Infinity"
                                  style="-fx-background-color: #FFFFFF; -fx-border-color: #CED4DA; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 13px; -fx-pref-height: 38px;"
                                  promptText="Select report type..."/>
                        <Label fx:id="lblTypeError" text="" style="-fx-text-fill: #DC3545; -fx-font-size: 11px; -fx-font-weight: 500;" visible="false" managed="false"/>
                    </VBox>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Date Range" style="-fx-font-size: 12px; -fx-font-weight: 500; -fx-text-fill: #495057;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <DatePicker fx:id="dpDateStart" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                        style="-fx-font-size: 13px; -fx-pref-height: 38px;" promptText="Start Date"/>
                            <Label text="to" style="-fx-font-size: 13px; -fx-text-fill: #6C757D;"/>
                            <DatePicker fx:id="dpDateEnd" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                        style="-fx-font-size: 13px; -fx-pref-height: 38px;" promptText="End Date"/>
                        </HBox>
                        <Label fx:id="lblDateError" text="" style="-fx-text-fill: #DC3545; -fx-font-size: 11px; -fx-font-weight: 500;" visible="false" managed="false"/>
                    </VBox>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 4 0 0 0;">
                    <Button fx:id="btnGenerate" text="Generate Report" onAction="#generateReport"
                            style="-fx-background-color: #7A0000; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0 22; -fx-background-radius: 6; -fx-cursor: hand; -fx-pref-height: 38px;">
                        <graphic>
                            <Label text="📄" style="-fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 0 6 0 0;"/>
                        </graphic>
                    </Button>
                    <Label fx:id="lblGlobalError" text="" style="-fx-text-fill: #DC3545; -fx-font-size: 12px; -fx-font-weight: bold;" visible="false" managed="false"/>
                </HBox>
            </VBox>

            <VBox style="-fx-background-color: #FFFFFF; -fx-background-radius: 8; -fx-border-color: #E9ECEF; -fx-border-radius: 8; -fx-padding: 24;" spacing="16" VBox.vgrow="ALWAYS">
                <Label text="Generated Reports Archive" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #212529;"/>

                <TableView fx:id="tblReports" style="-fx-background-color: #FFFFFF; -fx-border-color: #E9ECEF; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 0;" VBox.vgrow="ALWAYS" minHeight="380">
                    <columns>
                        <TableColumn fx:id="colTitle" text="TITLE" prefWidth="250"/>
                        <TableColumn fx:id="colType" text="TYPE" prefWidth="130"/>
                        <TableColumn fx:id="colDateRange" text="DATE RANGE" prefWidth="210"/>
                        <TableColumn fx:id="colRecords" text="RECORDS" prefWidth="100"/>
                        <TableColumn fx:id="colGenerated" text="GENERATED" prefWidth="160"/>
                        <TableColumn fx:id="colExport" text="EXPORT" prefWidth="90" style="-fx-alignment: CENTER;"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <placeholder>
                        <Label text="No records processed within historical archive metrics." style="-fx-text-fill: #868E96; -fx-font-size: 13px;"/>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>