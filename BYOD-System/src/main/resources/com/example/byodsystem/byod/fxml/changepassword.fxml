<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>

<BorderPane style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.byodsystem.byod.controller.ChangePasswordController">
    <center>
        <VBox alignment="TOP_CENTER" spacing="24.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
            <children>
                <VBox spacing="6.0">
                    <children>
                        <Label text="Change Password" textFill="#111111">
                            <font>
                                <Font name="System Bold" size="22.0" />
                            </font>
                        </Label>
                        <Label text="Update your account password" textFill="#6C757D">
                            <font>
                                <Font size="13.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <VBox maxWidth="600.0" prefWidth="600.0" spacing="24.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-border-color: #E5E7EB; -fx-border-radius: 16;">
                    <padding>
                        <Insets bottom="32.0" left="32.0" right="32.0" top="32.0" />
                    </padding>
                    <effect>
                        <DropShadow blurType="GAUSSIAN" height="30.0" radius="14.5" width="30.0">
                            <color>
                                <Color red="0.0" green="0.0" blue="0.0" opacity="0.03" />
                            </color>
                        </DropShadow>
                    </effect>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="16.0" style="-fx-border-color: #F3F4F6; -fx-border-width: 0 0 1 0; -fx-padding: 0 0 16 0;">
                            <children>
                                <StackPane maxHeight="40.0" maxWidth="40.0" minHeight="40.0" minWidth="40.0" style="-fx-background-color: #7A0000; -fx-background-radius: 10;">
                                    <children>
                                        <Label text="🔑" textFill="WHITE">
                                            <font>
                                                <Font size="18.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </StackPane>
                                <VBox spacing="2.0">
                                    <children>
                                        <Label text="Security Settings" textFill="#111111">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Label>
                                        <Label text="Ensure your password is strong and secure" textFill="#6C757D">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="18.0">
                            <children>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Current Password" textFill="#495057">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="currentPasswordTextField" prefHeight="46.0" promptText="Enter current password" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 45 0 14; -fx-text-fill: #1F2937;" visible="false">
                                                    <font>
                                                        <Font size="13.0" />
                                                    </font>
                                                </TextField>
                                                <PasswordField fx:id="currentPasswordField" prefHeight="46.0" promptText="Enter current password" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 45 0 14; -fx-text-fill: #1F2937;">
                                                    <font>
                                                        <Font size="13.0" />
                                                    </font>
                                                </PasswordField>
                                                <Button fx:id="toggleCurrentPasswordBtn" mnemonicParsing="false" onAction="#toggleCurrentPasswordVisibility" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 16 0 0;" text="🙈" textFill="#9CA3AF">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Button>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="New Password" textFill="#495057">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="newPasswordTextField" prefHeight="46.0" promptText="Enter new password" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 45 0 14; -fx-text-fill: #1F2937;" visible="false">
                                                    <font>
                                                        <Font size="13.0" />
                                                    </font>
                                                </TextField>
                                                <PasswordField fx:id="newPasswordField" prefHeight="46.0" promptText="Enter new password" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 45 0 14; -fx-text-fill: #1F2937;">
                                                    <font>
                                                        <Font size="13.0" />
                                                    </font>
                                                </PasswordField>
                                                <Button fx:id="toggleNewPasswordBtn" mnemonicParsing="false" onAction="#toggleNewPasswordVisibility" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 16 0 0;" text="🙈" textFill="#9CA3AF">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Button>
                                            </children>
                                        </StackPane>
                                        <Label text="Must be at least 8 characters with letters and numbers" textFill="#9CA3AF">
                                            <font>
                                                <Font size="11.0" />
                                            </font>
                                            <VBox.margin>
                                                <Insets top="2.0" />
                                            </VBox.margin>
                                        </Label>
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label text="Confirm New Password" textFill="#495057">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                        <StackPane alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="confirmPasswordTextField" prefHeight="46.0" promptText="Confirm new password" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 45 0 14; -fx-text-fill: #1F2937;" visible="false">
                                                    <font>
                                                        <Font size="13.0" />
                                                    </font>
                                                </TextField>
                                                <PasswordField fx:id="confirmPasswordField" prefHeight="46.0" promptText="Confirm new password" style="-fx-background-color: #FFFFFF; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 0 45 0 14; -fx-text-fill: #1F2937;">
                                                    <font>
                                                        <Font size="13.0" />
                                                    </font>
                                                </PasswordField>
                                                <Button fx:id="toggleConfirmPasswordBtn" mnemonicParsing="false" onAction="#toggleConfirmPasswordVisibility" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 16 0 0;" text="🙈" textFill="#9CA3AF">
                                                    <font>
                                                        <Font size="16.0" />
                                                    </font>
                                                </Button>
                                            </children>
                                        </StackPane>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <Label fx:id="errorLabel" visible="false" managed="false" wrapText="true" textFill="#DC2626">
                            <font>
                                <Font name="System Bold" size="12.0" />
                            </font>
                        </Label>

                        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleUpdatePassword" prefHeight="46.0" style="-fx-background-color: #7A0000; -fx-background-radius: 10; -fx-cursor: hand;" text="Update Password" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="8.0" />
                            </VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>