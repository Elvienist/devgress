                                        <Button mnemonicParsing="false" onAction="#handleEditDeviceFromProfile" style="-fx-background-color: #FEF3C7; -fx-cursor: hand; -fx-text-fill: #D97706; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-border-color: #FCD34D; -fx-border-radius: 8;" text="📝 Edit" />
                                    </children>
                                </HBox>
                                <HBox spacing="14.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #EEF2F6; -fx-border-radius: 10;">
