                                                <Label fx:id="lblProfileDeviceBrand" text="-" textFill="#1E293B"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #EEF2F6; -fx-border-radius: 10;">
                                            <padding><Insets bottom="12.0" left="14.0" right="14.0" top="10.0" /></padding>
                                            <children>
                                                <Label text="MODEL REFERENCE NAME" textFill="#94A3B8"><font><Font name="System Bold" size="11.0" /></font></Label>
                                                <Label fx:id="lblProfileDeviceModel" text="-" textFill="#1E293B"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="14.0" alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #EEF2F6; -fx-border-radius: 10;">
                                            <padding><Insets bottom="12.0" left="14.0" right="14.0" top="10.0" /></padding>
                                            <children>
                                                <Label text="REGISTERED OWNER" textFill="#94A3B8"><font><Font name="System Bold" size="11.0" /></font></Label>
                                                <Label fx:id="lblProfileDeviceOwner" text="-" textFill="#1E293B"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" onAction="#handleGoToOwnerProfile" style="-fx-background-color: #F1F5F9; -fx-text-fill: #7A0000; -fx-background-radius: 8; -fx-padding: 8 16; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: #E2E8F0; -fx-border-radius: 8;" text="👤 View Owner's Student Profile" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <VBox spacing="16.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 14; -fx-border-color: #E2E8F0; -fx-border-radius: 14; -fx-effect: dropshadow(three-pass-box, rgba(15,23,42,0.04), 10, 0, 0, 2);" VBox.vgrow="ALWAYS">
                            <padding><Insets bottom="24.0" left="24.0" right="24.0" top="24.0" /></padding>
                            <children>
                                <Label text="Full Log History" textFill="#7A0000">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <TableView fx:id="tblDeviceActivityLog" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colDLogTimeIn" minWidth="140.0" prefWidth="160.0" text="Time In" />
                                        <TableColumn fx:id="colDLogTimeOut" minWidth="140.0" prefWidth="160.0" text="Time Out" />
                                        <TableColumn fx:id="colDLogStatus" minWidth="110.0" prefWidth="120.0" style="-fx-alignment: CENTER;" text="Status" />
