                                                <Label fx:id="lblProfileDeviceSerial" text="-" textFill="#1E293B"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </VBox>
                                        <VBox spacing="4.0" prefWidth="200.0" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #EEF2F6; -fx-border-radius: 10;">
                                            <padding><Insets bottom="12.0" left="14.0" right="14.0" top="10.0" /></padding>
                                            <children>
                                                <Label text="DEVICE CATEGORY TYPE" textFill="#94A3B8"><font><Font name="System Bold" size="11.0" /></font></Label>
                                                <Label fx:id="lblProfileDeviceType" text="-" textFill="#1E293B"><font><Font name="System Bold" size="14.0" /></font></Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox spacing="14.0">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #F8FAFC; -fx-background-radius: 10; -fx-border-color: #EEF2F6; -fx-border-radius: 10;">
                                            <padding><Insets bottom="12.0" left="14.0" right="14.0" top="10.0" /></padding>
                                            <children>
