<!-- Navigation Header link referencing dynamic owners profile view -->
<HBox alignment="CENTER_LEFT" spacing="8.0">
    <Hyperlink fx:id="lnkBackToOwner" style="-fx-font-size: 14px; -fx-text-fill: #8B1D1D; -fx-font-weight: bold; -fx-underline: false;" text="&lt; Back to Owner's Student Profile" />
</HBox>

<!-- Header Section (Properties display card) -->
<HBox alignment="CENTER_LEFT" spacing="24.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>

    <!-- Hardware Icon -->
    <VBox alignment="CENTER" prefHeight="80.0" prefWidth="80.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 12px;">
        <Label style="-fx-font-size: 32px; -fx-text-fill: #475569;" text="💻" />
    </VBox>

    <!-- Hardware details container -->
    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label fx:id="lblDeviceModel" style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="XPS 15" />
            <Label fx:id="lblSerialNum" style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 6px; -fx-font-weight: bold; -fx-font-size: 12px;" text="DL2024001">
                <padding>
                    <Insets bottom="2.0" left="8.0" right="8.0" top="2.0" />
                </padding>
            </Label>
            <Label fx:id="lblLocationStateBadge" style="-fx-background-color: #E0F2FE; -fx-text-fill: #0369A1; -fx-background-radius: 6px; -fx-font-weight: bold; -fx-font-size: 12px;" text="Inside Campus">
                <padding>
                    <Insets bottom="2.0" left="8.0" right="8.0" top="2.0" />
                </padding>
            </Label>
        </HBox>

        <!-- Attributes details grid layout -->
        <GridPane hgap="24.0" vgap="8.0">
            <columnConstraints>
                <ColumnConstraints hgrow="NEVER" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="NEVER" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            
            <Label style="-fx-text-fill: #64748B;" text="Brand:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="lblBrandValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="Dell" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label style="-fx-text-fill: #64748B;" text="Device Type:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="lblTypeValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="Laptop" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: #64748B;" text="Registered Owner:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <Label fx:id="lblOwnerValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="John Doe (STU-2024-001)" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <Label style="-fx-text-fill: #64748B;" text="Reg Date:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <Label fx:id="lblRegDateValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="May 12, 2024" GridPane.columnIndex="3" GridPane.rowIndex="1" />
        <rowConstraints>
           <RowConstraints />
           <RowConstraints />
        </rowConstraints>
        </GridPane>
    </VBox>

    <!-- Contextual editing controls -->
    <Button fx:id="btnEditDevice" style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand;" text="Edit Device">
        <padding>
            <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
        </padding>
    </Button>
</HBox>

<!-- Error/Notice bar showing unclosed logs if any -->
<HBox fx:id="pnlUnclosedLogWarning" alignment="CENTER_LEFT" spacing="12.0" style="-fx-background-color: #FFFBEB; -fx-background-radius: 8px; -fx-border-color: #FCD34D; -fx-border-radius: 8px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="12.0" left="16.0" right="16.0" top="12.0" />
    </padding>
    <Label style="-fx-font-size: 16px;" text="⚠️" />
    <Label style="-fx-text-fill: #B45309; -fx-font-weight: bold; -fx-font-size: 14px;" text="Warning: This device has an open check-in session. It was last logged as entering campus without a corresponding departure log." />
</HBox>

<!-- History Tracking Logs Section -->
<VBox spacing="16.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>

    <Label style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Check-in / Check-out Log History" />

    <TableView fx:id="tblLogHistory" style="-fx-background-radius: 8px; -fx-border-color: #E2E8F0; -fx-border-radius: 8px;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colLogId" prefWidth="100.0" text="Log ID" />
            <TableColumn fx:id="colLogDate" prefWidth="120.0" text="Date" />
            <TableColumn fx:id="colLogAction" prefWidth="120.0" text="Action (In/Out)" />
            <TableColumn fx:id="colLogTime" prefWidth="120.0" text="Time" />
            <TableColumn fx:id="colGateKeeper" prefWidth="160.0" text="Logged By" />
            <TableColumn fx:id="colLogStatus" prefWidth="130.0" text="Verification Status" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>
