<!-- Top Navigation Header Links -->
<HBox alignment="CENTER_LEFT" spacing="8.0">
    <Hyperlink fx:id="lnkBack" style="-fx-font-size: 14px; -fx-text-fill: #8B1D1D; -fx-font-weight: bold; -fx-underline: false;" text="&lt; Back to Students &amp; Devices" />
</HBox>

<!-- Header Section (Top Student Info Banner Card) -->
<HBox alignment="CENTER_LEFT" spacing="24.0" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>

    <!-- Placeholder Icon Representation -->
    <VBox alignment="CENTER" prefHeight="80.0" prefWidth="80.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 40px;">
        <Label style="-fx-font-size: 32px; -fx-text-fill: #475569;" text="JD" />
    </VBox>

    <!-- Profile Matrix Display -->
    <VBox spacing="12.0" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <Label fx:id="lblStudentName" style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="John Doe" />
            <Label fx:id="lblStudentId" style="-fx-background-color: #E2E8F0; -fx-text-fill: #475569; -fx-background-radius: 6px; -fx-font-weight: bold; -fx-font-size: 12px;" text="STU-2024-001">
                <padding>
                    <Insets bottom="2.0" left="8.0" right="8.0" top="2.0" />
                </padding>
            </Label>
        </HBox>

        <!-- Metadata details formatted using dynamic Grid -->
        <GridPane hgap="24.0" vgap="8.0">
            <columnConstraints>
                <ColumnConstraints hgrow="NEVER" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints hgrow="NEVER" minWidth="80.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            
            <Label style="-fx-text-fill: #64748B;" text="Course:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <Label fx:id="lblCourseValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="Computer Science" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label style="-fx-text-fill: #64748B;" text="Year Level:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <Label fx:id="lblYearValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="3rd Year" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label style="-fx-text-fill: #64748B;" text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <Label fx:id="lblEmailValue" style="-fx-text-fill: #1E293B; -fx-font-weight: bold;" text="john.doe@university.edu" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <Label style="-fx-text-fill: #64748B;" text="Status:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <Label fx:id="lblStatusBadge" style="-fx-background-color: #DCFCE7; -fx-text-fill: #15803D; -fx-background-radius: 6px; -fx-font-weight: bold;" text="Active" GridPane.columnIndex="3" GridPane.rowIndex="1">
                <padding>
                    <Insets bottom="2.0" left="8.0" right="8.0" top="2.0" />
                </padding>
            </Label>
        <rowConstraints>
           <RowConstraints />
           <RowConstraints />
        </rowConstraints>
        </GridPane>
    </VBox>

    <!-- Profile Edit Trigger -->
    <Button fx:id="btnEditProfile" style="-fx-background-color: transparent; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand;" text="Edit Profile">
        <padding>
            <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
        </padding>
    </Button>
</HBox>

<!-- Activity Summary Strip -->
<HBox alignment="CENTER" spacing="40.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="16.0" left="24.0" right="24.0" top="16.0" />
    </padding>
    
    <VBox alignment="CENTER" spacing="4.0" HBox.hgrow="ALWAYS">
        <Label fx:id="lblSummaryTotalEntries" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="45" />
        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="TOTAL ENTRIES" />
    </VBox>
    <VBox alignment="CENTER" spacing="4.0" HBox.hgrow="ALWAYS" style="-fx-border-color: #CBD5E1; -fx-border-width: 0 1px 0 1px;">
        <Label fx:id="lblSummaryTotalExits" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="43" />
        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="TOTAL EXITS" />
    </VBox>
    <VBox alignment="CENTER" spacing="4.0" HBox.hgrow="ALWAYS">
        <Label fx:id="lblSummaryLastSeen" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #15803D;" text="Today, 2:45 PM" />
        <Label style="-fx-text-fill: #64748B; -fx-font-size: 12px; -fx-font-weight: bold;" text="LAST SEEN STATUS" />
    </VBox>
    <VBox alignment="CENTER" HBox.hgrow="NEVER">
        <Hyperlink fx:id="lnkActivityLog" style="-fx-font-size: 13px; -fx-text-fill: #8B1D1D; -fx-font-weight: bold; -fx-underline: true;" text="View Full Activity Log" />
    </VBox>
</HBox>

<!-- Bottom Layout Area: Registered Devices Control -->
<VBox spacing="16.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-background-radius: 12px; -fx-border-color: #E2E8F0; -fx-border-radius: 12px; -fx-border-width: 1px;">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>

    <!-- Section Header Bar -->
    <HBox alignment="CENTER_LEFT" spacing="16.0">
        <Label style="-fx-font-family: 'Inter', 'Segoe UI'; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" text="Registered Devices" />
        
        <HBox spacing="10.0" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
            <!-- Status Filter toggle -->
            <HBox spacing="4.0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 8px; -fx-padding: 3px;">
                <ToggleButton fx:id="btnShowActiveDevices" selected="true" style="-fx-background-color: #FFFFFF; -fx-text-fill: #1E293B; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-font-size: 12px;" text="Active">
                    <toggleGroup>
                        <ToggleGroup fx:id="deviceStatusGroup" />
                    </toggleGroup>
                    <padding>
                        <Insets bottom="4.0" left="10.0" right="10.0" top="4.0" />
                    </padding>
                </ToggleButton>
                <ToggleButton fx:id="btnShowInactiveDevices" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-font-size: 12px;" text="Inactive" toggleGroup="$deviceStatusGroup">
                    <padding>
                        <Insets bottom="4.0" left="10.0" right="10.0" top="4.0" />
                    </padding>
                </ToggleButton>
            </HBox>

            <!-- Add Device Trigger button -->
            <Button fx:id="btnAddDevice" style="-fx-background-color: #8B1D1D; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-font-size: 13px; -fx-cursor: hand;" text="+ Add Device">
                <padding>
                    <Insets bottom="8.0" left="16.0" right="16.0" top="8.0" />
                </padding>
            </Button>
        </HBox>
    </HBox>

    <!-- Devices Table -->
    <TableView fx:id="tblRegisteredDevices" style="-fx-background-radius: 8px; -fx-border-color: #E2E8F0; -fx-border-radius: 8px;" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDeviceSerial" prefWidth="120.0" text="Serial Number" />
            <TableColumn fx:id="colDeviceBrand" prefWidth="120.0" text="Brand" />
            <TableColumn fx:id="colDeviceModel" prefWidth="140.0" text="Model" />
            <TableColumn fx:id="colDeviceType" prefWidth="110.0" text="Type" />
            <TableColumn fx:id="colDeviceStatus" prefWidth="110.0" text="Device State" />
            <TableColumn fx:id="colDeviceActions" prefWidth="150.0" text="Actions" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>
