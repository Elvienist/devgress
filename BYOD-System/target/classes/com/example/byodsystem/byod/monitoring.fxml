<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.byodsystem.byod.controller.MonitoringController">

    <top>
        <Label text="DEVICE MONITORING (INGRESS / EGRESS)"
               style="-fx-font-size: 18px; -fx-padding: 15;"/>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <ComboBox fx:id="deviceTypeCombo" promptText="Device Type"/>
            <TextField fx:id="deviceIdField" promptText="Device ID"/>
            <TextField fx:id="studentIdField" promptText="Student ID"/>
            <TextField fx:id="searchField" promptText="Search Student or Device"/>

            <HBox spacing="10">
                <Button text="Time In" onAction="#timeIn"/>
                <Button text="Time Out" onAction="#timeOut"/>
                <Button text="Search" onAction="#searchRecord"/>
            </HBox>

            <TableView fx:id="logTable">

                <columns>
                    <TableColumn fx:id="colLogId" text="Log ID"/>
                    <TableColumn fx:id="colDeviceId" text="Device ID"/>
                    <TableColumn fx:id="colStudentId" text="Student ID"/>
                    <TableColumn fx:id="colDeviceType" text="Device Type"/>
                    <TableColumn fx:id="colTimeIn" text="Time In"/>
                    <TableColumn fx:id="colTimeOut" text="Time Out"/>
                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>